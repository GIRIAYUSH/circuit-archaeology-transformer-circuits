      "execution_count": 88,
      "metadata": {
        "id": "SlOLMimptIqX"
      },
      "outputs": [],
      "source": [
        "overlap_matrix = compute_subspace_overlap(svd_results, model.cfg.n_layers, top_k=50)"
      ]
