      ],
      "source": [
        "norms = compute_residual_norms(cache,model.cfg.n_layers)\n",
        "# Also getting embedding norm\n",
        "embed_norm = torch.norm(model.embed(tokens)[0], dim=-1).cpu().detach().numpy()\n",
        "\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n",
        "\n",
        "# Left: Norm trajectory per layer (mean across tokens)\n",
        "ax1 = axes[0]\n",
        "layer_indices = np.arange(model.cfg.n_layers)\n",
        "mean_pre = norms['pre'].mean(axis=1)\n",
        "mean_mid = norms['mid'].mean(axis=1)\n",
        "mean_post = norms['post'].mean(axis=1)\n",
        "\n",
        "ax1.plot(layer_indices, mean_pre, 'o-', label='resid_pre (before attn)', linewidth=2)\n",
        "ax1.plot(layer_indices, mean_mid, 's-', label='resid_mid (after attn)', linewidth=2)\n",
        "ax1.plot(layer_indices, mean_post, '^-', label='resid_post (after MLP)', linewidth=2)\n",
        "ax1.axhline(y=embed_norm.mean(), color='gray', linestyle='--', label='Embedding norm')\n",
        "ax1.set_xlabel('Layer')\n",
        "ax1.set_ylabel('Mean L2 Norm')\n",
        "ax1.set_title('Residual Stream Norm Trajectory\\n(Mean across all token positions)')\n",
        "ax1.legend()\n",
        "ax1.grid(True, alpha=0.3)\n",
        "\n",
        "# Right: Norm heatmap across layers and positions\n",
        "ax2 = axes[1]\n",
        "im = ax2.imshow(norms['post'], aspect='auto', cmap='viridis')\n",
        "ax2.set_xlabel('Token Position')\n",
        "ax2.set_ylabel('Layer')\n",
        "ax2.set_title('Residual Stream Norm Heatmap\\n(resid_post, all positions)')\n",
        "plt.colorbar(im, ax=ax2, label='L2 Norm')\n",
        "\n",
        "# Add token labels on x-axis\n",
        "token_strs = model.to_str_tokens(prompt)\n",
        "ax2.set_xticks(range(len(token_strs)))\n",
        "ax2.set_xticklabels(token_strs, rotation=45, ha='right', fontsize=8)\n",
