      "source": [
        "# Plot singular value spectra\n",
        "fig, axes = plt.subplots(2, 2, figsize=(14, 10))\n",
        "\n",
        "# Plot 1: Singular value spectra for selected layers\n",
        "ax1 = axes[0, 0]\n",
        "selected_layers = [0, 3, 6, 9, 11]\n",
        "for l in selected_layers:\n",
        "    S = svd_results[l]['S']\n",
        "    ax1.semilogy(range(len(S)), S, 'o-', label=f'Layer {l}', linewidth=2, markersize=3)\n",
        "ax1.set_xlabel('Singular Value Index')\n",
        "ax1.set_ylabel('Singular Value (log scale)')\n",
        "ax1.set_title('Singular Value Spectra by Layer')\n",
        "ax1.legend()\n",
        "ax1.grid(True, alpha=0.3)\n",
        "\n",
        "# Plot 2: Cumulative variance explained\n",
        "ax2 = axes[0, 1]\n",
        "for l in selected_layers:\n",
        "    S = svd_results[l]['S']\n",
        "    cumvar = np.cumsum(S**2) / np.sum(S**2)\n",
        "    ax2.plot(range(len(cumvar)), cumvar, '-', label=f'Layer {l}', linewidth=2)\n",
        "ax2.set_xlabel('Number of Components')\n",
        "ax2.set_ylabel('Cumulative Variance Explained')\n",
        "ax2.set_title('Variance Compression by Layer')\n",
        "ax2.legend()\n",
        "ax2.grid(True, alpha=0.3)\n",
        "ax2.axhline(y=0.95, color='red', linestyle='--', alpha=0.5, label='95%')\n",
        "\n",
        "# Plot 3: Effective dimensionality (components for 95% variance)\n",
        "ax3 = axes[1, 0]\n",
        "eff_dims = []\n",
        "for l in range(model.cfg.n_layers):\n",
        "    S = svd_results[l]['S']\n",
        "    cumvar = np.cumsum(S**2) / np.sum(S**2)\n",
        "    eff_dim = np.argmax(cumvar >= 0.95) + 1\n",
        "    eff_dims.append(eff_dim)\n",
        "\n",
        "ax3.bar(range(model.cfg.n_layers), eff_dims, color='steelblue', alpha=0.7)\n",
        "ax3.set_xlabel('Layer')\n",
        "ax3.set_ylabel('Components for 95% Variance')\n",
        "ax3.set_title('Effective Dimensionality by Layer')\n",
        "ax3.axhline(y=model.cfg.d_model, color='red', linestyle='--', label=f'd_model={model.cfg.d_model}')\n",
        "ax3.legend()\n",
        "\n",
        "# Plot 4: Fraction of variance in top-k components\n",
        "ax4 = axes[1, 1]\n",
        "k_values = [1, 10, 50, 100, 256]\n",
        "colors = plt.cm.viridis(np.linspace(0, 1, len(k_values)))\n",
        "for k, color in zip(k_values, colors):\n",
        "    frac_vars = []\n",
        "    for l in range(model.cfg.n_layers):\n",
        "        S = svd_results[l]['S']\n",
        "        if k <= len(S):\n",
        "            frac = np.sum(S[:k]**2) / np.sum(S**2)\n",
        "        else:\n",
        "            frac = 1.0\n",
        "        frac_vars.append(frac)\n",
        "    ax4.plot(range(model.cfg.n_layers), frac_vars, 'o-', color=color, label=f'top-{k}', linewidth=2)\n",
        "\n",
        "ax4.set_xlabel('Layer')\n",
        "ax4.set_ylabel('Fraction of Variance Explained')\n",
        "ax4.set_title('Variance Explained by Top-k Components')\n",
        "ax4.legend()\n",
        "ax4.grid(True, alpha=0.3)\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.show()"
      ]
