      "outputs": [],
      "source": [
        "def analyze_residual_svd(cache, n_layers, batch_idx=0):\n",
        "    \"\"\"\n",
        "    Perform SVD on residual stream at each layer.\n",
        "    Returns singular values and right singular vectors.\n",
        "    \"\"\"\n",
        "    svd_results = {}\n",
        "\n",
        "    for l in range(n_layers):\n",
        "        # Get resid_post for this layer\n",
        "        X = cache[f'blocks.{l}.hook_resid_post'][batch_idx]  # [T, d_model]\n",
        "        X_np = X.cpu().numpy()\n",
        "\n",
        "        # SVD: X = U @ diag(S) @ Vh\n",
        "        U, S, Vh = np.linalg.svd(X_np, full_matrices=False)\n",
        "        V = Vh.T  # Right singular vectors [d_model, T]\n",
        "\n",
        "        svd_results[l] = {\n",
        "            'U': U,      # [T, T]\n",
        "            'S': S,      # [T] (singular values)\n",
        "            'V': V,      # [d_model, T]\n",
        "            'X': X_np\n",
        "        }\n",
        "\n",
        "    return svd_results\n",
        "\n",
        "svd_results = analyze_residual_svd(cache,model.cfg.n_layers)"
      ]
    },
