        "for l in range(model.cfg.n_layers):\n",
        "    if l == 0:\n",
        "        prev = cache['blocks.0.hook_resid_pre'][0].cpu().numpy().mean(axis=0)  # [d_model]\n",
        "    else:\n",
        "        prev = cache[f'blocks.{l-1}.hook_resid_post'][0].cpu().numpy().mean(axis=0)\n",
        "\n",
        "    curr = cache[f'blocks.{l}.hook_resid_post'][0].cpu().numpy().mean(axis=0)\n",
        "    contrib = contributions['total'][l].mean(axis=0)  # [d_model]\n",
        "\n",
        "    prev_norm = np.linalg.norm(prev)\n",
        "    curr_norm = np.linalg.norm(curr)\n",
        "    contrib_norm = np.linalg.norm(contrib)\n",
        "    cos_theta = np.dot(prev, contrib) / (prev_norm * contrib_norm + 1e-10)\n",
        "\n",
        "    actual_delta = curr_norm**2 - prev_norm**2\n",
        "    orthog = contrib_norm**2\n",
        "    align = 2 * prev_norm * contrib_norm * cos_theta\n",
        "\n",
        "    norm_changes.append(actual_delta)\n",
        "    orthog_terms.append(orthog)\n",
        "    align_terms.append(align)\n",
        "\n",
        "x_pos = np.arange(model.cfg.n_layers)\n",
        "width = 0.35\n",
        "\n",
        "# Use different colors for positive/negative alignment\n",
        "align_colors = ['coral' if v >= 0 else 'crimson' for v in align_terms]\n",
        "\n",
        "ax20.bar(x_pos - width/2, align_terms, width, label='$2||x|| ||Δx|| \\\\cos(\\\\theta)$',\n",
        "         color=align_colors, alpha=0.85, edgecolor='black', linewidth=0.5)\n",
        "ax20.bar(x_pos + width/2, orthog_terms, width, label='$||Δx||^2$',\n",
        "         color='skyblue', alpha=0.85, edgecolor='black', linewidth=0.5)\n",
        "\n",
        "# Plot actual with different marker for negative\n",
        "for i, (xi, yi) in enumerate(zip(x_pos, norm_changes)):\n",
        "    marker = 'o' if yi >= 0 else 'v'\n",
        "    color = 'black' if yi >= 0 else 'red'\n",
        "    ax20.plot(xi, yi, marker=marker, color=color, markersize=7, zorder=5)\n",
        "\n",
        "ax20.plot([], [], 'ko-', label='Actual $\\\\Delta(||x||^2)$')  # Dummy for legend\n",
        "\n",
        "ax20.set_xlabel('Layer', fontsize=11)\n",
        "ax20.set_ylabel('Squared Norm Change', fontsize=11)\n",
        "ax20.set_title('Geometric Decomposition of Norm Growth\\n$||x+\\\\Delta x||^2 = ||x||^2 + ||\\\\Delta x||^2 + 2||x|| ||\\\\Delta x|| \\\\cos(\\\\theta)$',\n",
        "              fontsize=11, fontweight='bold')\n",
        "ax20.legend(fontsize=8, loc='upper left')\n",
        "ax20.grid(True, alpha=0.3, axis='y')\n",
        "\n",
        "# 2,1: Summary statistics\n",
        "ax21 = fig.add_subplot(gs[2, 1])\n",
        "ax21.axis('off')\n",
        "\n",
        "mean_align = np.nanmean(alignments['total_vs_pre'])\n",
        "mean_attn_mlp = np.mean(alignments['attn_vs_mlp'])\n",
        "mean_conv = np.nanmean(alignments['consecutive_total'])\n",
        "\n",
        "constructive = sum(1 for a in alignments['total_vs_pre'] if a > 0.3)\n",
        "destructive = sum(1 for a in alignments['total_vs_pre'] if a < -0.3)\n",
        "orthogonal = sum(1 for a in alignments['total_vs_pre'] if -0.3 <= a <= 0.3)\n",
        "\n",
        "# Identify most interesting layers\n",
        "max_contrib_idx = np.argmax(total_norms)\n",
        "max_align_idx = np.argmax(alignments['total_vs_pre'])\n",
        "min_align_idx = np.argmin(alignments['total_vs_pre'])\n"
